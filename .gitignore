# Minimal, language-agnostic ignores. Add stack-specific entries per project.

# OS
.DS_Store
Thumbs.db

# Editors / IDEs
.idea/
.vscode/
*.swp

# Environment / secrets
.env
.venv/
venv/

# Logs / temp
*.log
tmp/

# Stack-specific ignores go here (see the README customize checklist). For example:
#   Python:  __pycache__/   *.py[cod]   .pytest_cache/
#   Node:    node_modules/   *.tsbuildinfo
#   Rust:    /target
